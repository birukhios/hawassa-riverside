# Copy to .env.local (dev) or set these in your host's environment.

# Database (Prisma). SQLite for local dev; use a hosted DB (e.g. Postgres) in prod
# and update prisma/schema.prisma datasource provider accordingly.
DATABASE_URL="file:./dev.db"

# AfroPay payment gateway — SERVER-SIDE ONLY (never prefixed with NEXT_PUBLIC).
AFROPAY_BASE_URL="https://paybridge.afropays.co/api/v1"
AFROPAY_API_KEY="your_afropay_api_key"

# Public site URL (used to build AfroPay redirect/callback URLs)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
